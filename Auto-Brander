import sys
import os
from PIL import Image, ImageOps


def main():
    input_file, output_file = check()
    image_watermark(input_file, output_file)


def check():
    if len(sys.argv)<3:
        sys.exit("Too few command-line arguments")
    if len(sys.argv)>3:
        sys.exit("Too many command-line arguments")
    split = os.path.splitext(sys.argv[1])
    if not split[1] in [".jpg", ".jpeg", ".png"]:
        sys.exit("Invalid input")
    split_2 = os.path.splitext(sys.argv[2])
    if split_2[1] != split[1]:
        sys.exit("Input and output have different extensions ")
    try:
        with open(sys.argv[1]) as f:
            pass
    except FileNotFoundError:
        sys.exit("Input does not exist")
    return sys.argv[1], sys.argv[2]

def image_watermark(filename1,filename2):
    logo = Image.open("bear.png")
    img = Image.open(filename1)
    new_image = ImageOps.fit((img), (1080, 1080))
    logo = logo.resize((150, 150))
    position = (new_image.width - logo.width, new_image.height - logo.height)
    new_image.paste(logo, position, logo)
    new_image.save(filename2)


main()



